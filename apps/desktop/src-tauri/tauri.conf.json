{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nyanko",
  "version": "0.1.0",
  "identifier": "app.nyanko.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Nyanko",
        "width": 1180,
        "height": 760,
        "minWidth": 760,
        "minHeight": 560,
        "center": true,
        "visible": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: http://127.0.0.1:8765 https://s4.anilist.co https://cdn.myanimelist.net https://media.kitsu.app https://media.kitsu.io; connect-src http://127.0.0.1:8765 ws://127.0.0.1:8765; style-src 'self' 'unsafe-inline'"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/kfernandoy/Nyanko/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJBQ0FCNjk0NzAyOEY2RDQKUldUVTlpaHdsTGJLdW9vN3A3MHVBaGtzNVloMlcrSnVOckNWbVQyVXRjV2N3c0JSdURYbVM4YUEK"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "externalBin": ["binaries/nyanko-api"],
    "createUpdaterArtifacts": true,
    "licenseFile": "EULA.txt",
    "windows": {
      "nsis": {
        "languages": ["Spanish", "English"],
        "displayLanguageSelector": true
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ]
  }
}
