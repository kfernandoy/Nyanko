{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nyanko",
  "version": "0.1.0",
  "identifier": "app.nyanko.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Nyanko",
        "width": 1180,
        "height": 760,
        "minWidth": 760,
        "minHeight": 560,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' https://s4.anilist.co data:; connect-src http://127.0.0.1:8765 ws://127.0.0.1:8765; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/nyanko-api"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ]
  }
}
