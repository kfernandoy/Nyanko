{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    {
      "identifier": "opener:allow-open-path",
      "allow": [{ "path": "**" }]
    },
    "autostart:default",
    "dialog:default",
    "shell:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [{"name": "binaries/nyanko-api", "sidecar": true}]
    },
    "notification:default",
    "fs:default",
    {
      "identifier": "fs:allow-read-text-file",
      "allow": [{"path": "$APPDATA/nyanko/port"}, {"path": "$APPDATA/nyanko/instance_token"}]
    }
  ]
}
