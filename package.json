{
  "private": true,
  "workspaces": ["apps/desktop", "apps/extension"],
  "scripts": {
    "dev": "concurrently -k -n backend,desktop -c blue,magenta \"npm:dev:backend\" \"npm:dev:desktop\"",
    "dev:backend": "apps\\backend\\.venv\\Scripts\\python.exe -m uvicorn nyanko_api.main:app --app-dir apps/backend --reload --reload-dir apps/backend/nyanko_api --port 8765",
    "dev:desktop": "npm run tauri --workspace @nyanko/desktop -- dev",
    "build:sidecar": ".\\apps\\backend\\.venv\\Scripts\\Activate.ps1; python apps/backend/scripts/build_sidecar.py",
    "build:icons": "node apps/desktop/scripts/generate-icons.mjs",
    "build:extension": "npm run build --workspace @nyanko/extension",
    "build": "npm run build:icons && npm run build:sidecar && npm run build --workspace @nyanko/desktop",
    "check": "npm run check --workspace @nyanko/desktop",
    "legacy:css": "tailwindcss -i legacy/static/tailwind/tailwind-input.css -o legacy/static/styles/nyanko.css --watch"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.14",
    "daisyui": "^3.5.1",
    "postcss": "^8.4.26",
    "tailwind-scrollbar": "^3.0.4",
    "tailwindcss": "^3.3.3",
    "concurrently": "^9.2.1"
  },
  "dependencies": {
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.3",
    "@tailwindcss/line-clamp": "^0.4.4",
    "@tailwindcss/typography": "^0.5.9",
    "alpinejs": "^3.12.3",
    "bulma": "^0.9.4",
    "tw-elements": "^1.0.0-beta2"
  }
}
